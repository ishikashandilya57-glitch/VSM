# Google Sheets Configuration

# DBR Factory
DBR_GOOGLE_SHEET_ID=your_dbr_sheet_id_here
DBR_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your_dbr_script_id/exec

# KPR Factory
KPR_GOOGLE_SHEET_ID=your_kpr_sheet_id_here
KPR_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/your_kpr_script_id/exec

# Google Service Account (for server-side access if needed)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Note: All factory-specific URLs should point to a deployed Google Apps Script 
# that handles 'getIntegratedData', 'getLines', and other VSM actions.
